<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_menu_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    tools:ignore="ContentDescription">

    <!-- ============================================== -->
    <!-- RIGHT SIDE - PROFILE & PLAY (Now on TOP area) -->
    <!-- ============================================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/play_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottom_menu_card"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHeight_percent="0.62">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/play_main_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/play_buttons_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- ======== ACCOUNT VIEW (Centered Top) ======== -->
                <include
                    android:id="@+id/view_account"
                    layout="@layout/view_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_16sdp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- ======== VERSION SELECTOR CARD (Redesigned) ======== -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/version_card_wrapper"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_24sdp"
                    android:layout_marginEnd="@dimen/_24sdp"
                    android:layout_marginBottom="@dimen/_12sdp"
                    app:cardBackgroundColor="#2A2D3A"
                    app:cardCornerRadius="@dimen/_16sdp"
                    app:cardElevation="@dimen/_8sdp"
                    app:layout_constraintBottom_toTopOf="@+id/play_button"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:strokeColor="#3D4155"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/_12sdp">

                        <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                            android:id="@+id/version"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/manager_profile_button"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <!-- Version Icon with Glow Background -->
                            <FrameLayout
                                android:id="@+id/version_icon_frame"
                                android:layout_width="@dimen/_44sdp"
                                android:layout_height="@dimen/_44sdp"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="@dimen/_4sdp"
                                android:background="@drawable/background_item"
                                android:backgroundTint="#363A4E">

                                <ImageView
                                    android:id="@+id/version_icon"
                                    android:layout_width="@dimen/_32sdp"
                                    android:layout_height="@dimen/_32sdp"
                                    android:layout_gravity="center"
                                    android:scaleType="centerInside"
                                    android:src="@drawable/ic_minecraft" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="@dimen/_12sdp"
                                android:layout_marginEnd="@dimen/_4sdp"
                                android:layout_toEndOf="@id/version_icon_frame"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/main_launch"
                                    android:textColor="#8E91A4"
                                    android:textSize="@dimen/_9sdp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.08" />

                                <TextView
                                    android:id="@+id/version_name"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/_2sdp"
                                    android:ellipsize="marquee"
                                    android:focusable="true"
                                    android:focusableInTouchMode="true"
                                    android:gravity="start"
                                    android:marqueeRepeatLimit="marquee_forever"
                                    android:scrollHorizontally="true"
                                    android:singleLine="true"
                                    android:text="@string/version_no_versions"
                                    android:textColor="@color/primary_text"
                                    android:textSize="@dimen/_12sdp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/version_info"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/_1sdp"
                                    android:ellipsize="marquee"
                                    android:focusable="true"
                                    android:focusableInTouchMode="true"
                                    android:gravity="start"
                                    android:marqueeRepeatLimit="marquee_forever"
                                    android:scrollHorizontally="true"
                                    android:singleLine="true"
                                    android:textColor="#8E91A4"
                                    android:textSize="@dimen/_10sdp"
                                    android:visibility="gone" />

                            </LinearLayout>

                        </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>

                        <!-- Settings Gear Button (Redesigned) -->
                        <ImageButton
                            android:id="@+id/manager_profile_button"
                            android:layout_width="@dimen/_40sdp"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/background_item"
                            android:backgroundTint="#363A4E"
                            android:padding="@dimen/_8sdp"
                            android:scaleType="centerInside"
                            android:src="@drawable/ic_setting"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ======== PLAY BUTTON (Completely Redesigned) ======== -->
                <com.movtery.zalithlauncher.ui.view.AnimButton
                    android:id="@+id/play_button"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_48sdp"
                    android:layout_marginHorizontal="@dimen/_24sdp"
                    android:layout_marginBottom="@dimen/_16sdp"
                    android:background="@drawable/background_item"
                    android:backgroundTint="#4CAF50"
                    android:letterSpacing="0.15"
                    android:text="▶  LAUNCH GAME"
                    android:textAllCaps="true"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/_13sdp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ============================================== -->
    <!-- BOTTOM - HORIZONTAL SCROLLABLE MENU BUTTONS    -->
    <!-- (Completely repositioned from left side)       -->
    <!-- ============================================== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_menu_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardBackgroundColor="#1E2030"
        app:cardCornerRadius="@dimen/_20sdp"
        app:cardElevation="@dimen/_12sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHeight_percent="0.38"
        app:strokeColor="#2D3148"
        app:strokeWidth="1dp">

        <!-- Shadow Line on Top -->
        <View
            android:id="@+id/shadowView"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_4sdp"
            android:background="@drawable/shadow_gradient_right"
            android:rotation="90" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/launcher_menu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="@dimen/_8sdp">

            <!-- Section Title -->
            <TextView
                android:id="@+id/menu_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_20sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:text="Quick Actions"
                android:textColor="#8E91A4"
                android:textSize="@dimen/_11sdp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Horizontal Scrolling Menu Items -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/_8sdp"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:fadingEdge="horizontal"
                android:fadingEdgeLength="@dimen/_24sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/menu_title">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/_16sdp"
                    android:clipToPadding="false">

                    <!-- ===== ABOUT BUTTON (Grid Card Style) ===== -->
                    <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                        android:id="@+id/about_button"
                        android:layout_width="@dimen/_108sdp"
                        android:layout_height="@dimen/_96sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:background="@drawable/background_item"
                        android:backgroundTint="#252839"
                        android:translationZ="4dp"
                        android:padding="@dimen/_12sdp"
                        app:ripple_for_relative="true">

                        <FrameLayout
                            android:id="@+id/about_icon_bg"
                            android:layout_width="@dimen/_42sdp"
                            android:layout_height="@dimen/_42sdp"
                            android:layout_centerHorizontal="true"
                            android:background="@drawable/background_item"
                            android:backgroundTint="#3A3D52">

                            <ImageView
                                android:id="@+id/about_icon"
                                android:layout_width="@dimen/_24sdp"
                                android:layout_height="@dimen/_24sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_about"
                                app:tint="#7C8AFF" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/about_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/about_icon_bg"
                            android:layout_marginTop="@dimen/_8sdp"
                            android:gravity="center"
                            android:singleLine="true"
                            android:ellipsize="marquee"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_10sdp"
                            android:textStyle="bold" />

                    </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>

                    <!-- ===== CUSTOM CONTROLS BUTTON ===== -->
                    <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                        android:id="@+id/custom_control_button"
                        android:layout_width="@dimen/_108sdp"
                        android:layout_height="@dimen/_96sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:background="@drawable/background_item"
                        android:backgroundTint="#252839"
                        android:translationZ="4dp"
                        android:padding="@dimen/_12sdp"
                        app:ripple_for_relative="true">

                        <FrameLayout
                            android:id="@+id/custom_control_icon_bg"
                            android:layout_width="@dimen/_42sdp"
                            android:layout_height="@dimen/_42sdp"
                            android:layout_centerHorizontal="true"
                            android:background="@drawable/background_item"
                            android:backgroundTint="#3A3D52">

                            <ImageView
                                android:id="@+id/custom_control_icon"
                                android:layout_width="@dimen/_24sdp"
                                android:layout_height="@dimen/_24sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_menu_custom_controls"
                                app:tint="#FF8A65" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/custom_control_icon_bg"
                            android:layout_marginTop="@dimen/_8sdp"
                            android:gravity="center"
                            android:singleLine="true"
                            android:ellipsize="marquee"
                            android:text="@string/custom_control_title"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_10sdp"
                            android:textStyle="bold" />

                    </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>

                    <!-- ===== OPEN MAIN DIR BUTTON ===== -->
                    <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                        android:id="@+id/open_main_dir_button"
                        android:layout_width="@dimen/_108sdp"
                        android:layout_height="@dimen/_96sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:background="@drawable/background_item"
                        android:backgroundTint="#252839"
                        android:translationZ="4dp"
                        android:padding="@dimen/_12sdp"
                        app:ripple_for_relative="true">

                        <FrameLayout
                            android:id="@+id/open_main_dir_icon_bg"
                            android:layout_width="@dimen/_42sdp"
                            android:layout_height="@dimen/_42sdp"
                            android:layout_centerHorizontal="true"
                            android:background="@drawable/background_item"
                            android:backgroundTint="#3A3D52">

                            <ImageView
                                android:id="@+id/open_main_dir_icon"
                                android:layout_width="@dimen/_24sdp"
                                android:layout_height="@dimen/_24sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_folder"
                                app:tint="#66BB6A" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/open_main_dir_icon_bg"
                            android:layout_marginTop="@dimen/_8sdp"
                            android:gravity="center"
                            android:singleLine="true"
                            android:ellipsize="marquee"
                            android:text="@string/main_open_main_dir"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_10sdp"
                            android:textStyle="bold" />

                    </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>

                    <!-- ===== INSTALL JAR BUTTON ===== -->
                    <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                        android:id="@+id/install_jar_button"
                        android:layout_width="@dimen/_108sdp"
                        android:layout_height="@dimen/_96sdp"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:background="@drawable/background_item"
                        android:backgroundTint="#252839"
                        android:translationZ="4dp"
                        android:padding="@dimen/_12sdp"
                        app:ripple_for_relative="true">

                        <FrameLayout
                            android:id="@+id/install_jar_icon_bg"
                            android:layout_width="@dimen/_42sdp"
                            android:layout_height="@dimen/_42sdp"
                            android:layout_centerHorizontal="true"
                            android:background="@drawable/background_item"
                            android:backgroundTint="#3A3D52">

                            <ImageView
                                android:id="@+id/install_jar_icon"
                                android:layout_width="@dimen/_24sdp"
                                android:layout_height="@dimen/_24sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_java"
                                app:tint="#42A5F5" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/install_jar_icon_bg"
                            android:layout_marginTop="@dimen/_8sdp"
                            android:gravity="center"
                            android:singleLine="true"
                            android:ellipsize="marquee"
                            android:text="@string/main_install_jar_file"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_10sdp"
                            android:textStyle="bold" />

                    </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>

                    <!-- ===== SHARE LOGS BUTTON ===== -->
                    <com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout
                        android:id="@+id/share_logs_button"
                        android:layout_width="@dimen/_108sdp"
                        android:layout_height="@dimen/_96sdp"
                        android:background="@drawable/background_item"
                        android:backgroundTint="#252839"
                        android:translationZ="4dp"
                        android:padding="@dimen/_12sdp"
                        app:ripple_for_relative="true">

                        <FrameLayout
                            android:id="@+id/share_logs_icon_bg"
                            android:layout_width="@dimen/_42sdp"
                            android:layout_height="@dimen/_42sdp"
                            android:layout_centerHorizontal="true"
                            android:background="@drawable/background_item"
                            android:backgroundTint="#3A3D52">

                            <ImageView
                                android:id="@+id/share_logs_icon"
                                android:layout_width="@dimen/_24sdp"
                                android:layout_height="@dimen/_24sdp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_share"
                                app:tint="#AB47BC" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/share_logs_icon_bg"
                            android:layout_marginTop="@dimen/_8sdp"
                            android:gravity="center"
                            android:singleLine="true"
                            android:ellipsize="marquee"
                            android:text="@string/main_share_logs"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_10sdp"
                            android:textStyle="bold" />

                    </com.movtery.zalithlauncher.ui.layout.AnimRelativeLayout>

                </LinearLayout>

            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
